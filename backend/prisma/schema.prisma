datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
generator client {
  provider = "prisma-client-js"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
}

model Book {
  id      String  @id @default(uuid())
  name    String
  type    String
  balance Float

  transactions Transaction[]
}

model Transaction {
  id       String   @id @default(uuid())
  title    String
  amount   Float
  category String
  location String
  date     DateTime
  type     String

  bookId String
  book   Book @relation(fields: [bookId], references: [id])
}
