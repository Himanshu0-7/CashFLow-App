datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
}

model Entry {
  id            String   @id @default(uuid())
  userId        String
  encryptedData String
  createdAt     DateTime @default(now())
}
